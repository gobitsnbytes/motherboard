# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=       # OAuth2 client secret (for web login)
GUILD_ID=
LOG_CHANNEL_ID=          # Channel ID for bot logs and monitoring
REDIRECT_URI=            # OAuth redirect (e.g., https://cal.gobitsnbytes.org/auth/callback)

# Web Push Notifications (VAPID)
VAPID_PUBLIC_KEY=        # Generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@gobitsnbytes.org

# Notion
NOTION_TOKEN=
NOTION_FORK_REGISTRY_DB=

# Notion Extended Databases (Phase 2-3 features)
NOTION_TEAM_DB=          # Team members database
NOTION_EVENTS_DB=        # Events database
NOTION_REPORTS_DB=       # Reports database
NOTION_REMINDERS_DB=     # Smart reminders tracking database

# Fork Handbook
FORK_HANDBOOK_URL=https://www.notion.so/33949ed2fc33818ba073ffa2d815bf1a?v=33949ed2fc3380ccbfe2000c860aa29a&source=copy_link

# Discord Role IDs
STAFF_ROLE_ID=
FORK_LEAD_ROLE_ID=
EVERYONE_ROLE_ID=
EVENTS_CHANNEL_ID=

# Email (SMTP)
SMTP_HOST=                # SMTP server hostname
SMTP_PORT=587             # SMTP port (587 for STARTTLS)
SMTP_USER=                # SMTP username (full email)
SMTP_PASS=                # SMTP password
SMTP_FROM=                # From header (e.g., "Bits&Bytes <hello@gobitsnbytes.org>")

# Cal.com Integration
CALCOM_API_KEY=            # Cal.com API key (Settings → Developer → API Keys)
CALCOM_TEAM_SLUG=          # Cal.com team slug (e.g., bitsnbytes)
CALCOM_WEBHOOK_SECRET=     # Webhook signing secret (optional, for webhook mode)
WEBHOOK_PORT=3100          # Port for webhook receiver (optional)

# Meeting Recording & Transcription
RECORDING_ENABLED=true                            # Master toggle for meeting recording
GEMINI_API_KEY=                                   # Google AI Studio API key
GEMINI_MODEL=gemini-3.5-flash                     # Primary transcription model
GEMINI_FALLBACK_MODEL=gemini-2.5-flash            # Fallback model if primary fails

# Multi-Bot Listener Pool (Optional - leave blank to fall back to main bot)
LISTENER_TOKEN_1=
LISTENER_TOKEN_2=
LISTENER_TOKEN_3=
LISTENER_TOKEN_4=

# FFmpeg Audio Offload (GitHub Actions)
GITHUB_DISPATCH_TOKEN=    # Fine-grained PAT with Actions write scope
FFMPEG_CALLBACK_SECRET=   # 32-char random shared secret for webhook validation
VPS_BASE_URL=             # Public HTTPS URL of the VPS (e.g., https://cal.gobitsnbytes.org)

# Motherboard Centralized API Integration
MOTHERBOARD_API_URL=http://localhost:8000
API_INTERNAL_SECRET=


