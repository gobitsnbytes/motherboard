# ==============================================================================
# BNB API - Production Environment Configuration
# ==============================================================================

# --- DATABASE SETUP (Neon Postgres) ---
# NOTE: SQLAlchemy asyncpg driver requires the 'postgresql+asyncpg://' prefix
DATABASE_URL="postgresql+asyncpg://neondb_owner:YOUR_DB_PASSWORD@ep-wandering-feather-aofk6nyk-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# --- CACHE / EVENT BUS (Upstash Redis) ---
REDIS_URL="rediss://default:YOUR_UPSTASH_TOKEN@balanced-macaque-94710.upstash.io:6379"

# --- DISCORD OAUTH INTEGRATION ---
DISCORD_CLIENT_ID="1490422414847381584"
DISCORD_CLIENT_SECRET="YOUR_DISCORD_CLIENT_SECRET"
DISCORD_BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN"
DISCORD_GUILD_ID="1480617556292272260"

# --- SECURITY / APP SECRETS ---
# (Generated automatically by setup.sh if left empty, or set them manually)
SESSION_SECRET=""
API_INTERNAL_SECRET=""
NEXTAUTH_SECRET=""

# --- APPLICATION URLS ---
NEXTAUTH_URL="https://gobitsnbytes.org"
API_URL="https://api.gobitsnbytes.org"

# --- CORS ORIGINS ---
# Comma-separated list of allowed origins. Defaults to NEXTAUTH_URL if left empty.
CORS_ORIGINS="https://gobitsnbytes.org"

# --- EMAIL SERVICE (SMTP) ---
SMTP_HOST="mail.gobitsnbytes.org"
SMTP_PORT=587
SMTP_USER="hello@gobitsnbytes.org"
SMTP_PASS="YOUR_SMTP_PASSWORD"
SMTP_FROM="bits&bytes™ <hello@gobitsnbytes.org>"

# --- OTHER SETTINGS ---
ENABLE_SYNC_SCHEDULER="false"
SYNC_INTERVAL_MINUTES=15
