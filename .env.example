# bnb-motherboard Environment Variables Template
# Copy this file to .env and configure the values. Do not commit .env to version control.

# --- Discord Integration ---
# Retrieve from the Discord Developer Portal -> OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Bot token for guild member/role sync (Discord Developer Portal -> Bot)
DISCORD_BOT_TOKEN=your_discord_bot_token

# The bits&bytes Discord Guild (Server) ID (Right-click server -> Copy Server ID)
DISCORD_GUILD_ID=your_discord_guild_id


# --- Database & Caching ---
# PostgreSQL connection string
DATABASE_URL=postgres://bnb:changeme@localhost:5432/motherboard

# Redis connection string (if applicable)
REDIS_URL=redis://localhost:6379


# --- Security & Session Management ---
# Long random string for session cookie signing (e.g. generate with: `openssl rand -hex 64`)
SESSION_SECRET=your_session_secret

# Shared secret between API and Bot integration (e.g. generate with: `openssl rand -hex 32`)
API_INTERNAL_SECRET=your_api_internal_secret

# NextAuth.js secret (e.g. generate with: `openssl rand -hex 32`)
NEXTAUTH_SECRET=your_nextauth_secret


# --- URLs & Routing ---
# Public URL of the Next.js App (VPS domain or http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# URL of Fastify API (http://api:4000 in docker-compose, http://localhost:4000 locally)
API_URL=http://localhost:4000
